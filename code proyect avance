//CONTROL 
#include <Arduino.h>
#include "Matrix8x8.h"

#define PIN 6

Matrix8x8 matrix(PIN, 8, 8);

void setup() {
    matrix.begin();
}

void loop() {

    // Señal digital
    for(int i=0; i<5; i++) {
        matrix.digitalSignal(500);
    }

    // Barrido
    matrix.sweep(100);

    // Nivel
    for(int i=0; i<=64; i++) {
        matrix.level(i, 50);
    }
}
